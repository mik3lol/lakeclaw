{
  "models": {
    "providers": {
      "databricks-openai": {
        "baseUrl": "http://127.0.0.1:${AI_GATEWAY_PROXY_PORT}/serving-endpoints",
        "apiKey": "${AI_GATEWAY_PROXY_LOCAL_KEY}",
        "api": "openai-responses",
        "models": [
          {
            "id": "databricks-gpt-5-4",
            "name": "GPT 5.4"
          }
        ]
      },
      "databricks-anthropic": {
        "baseUrl": "http://127.0.0.1:${AI_GATEWAY_PROXY_PORT}/anthropic",
        "apiKey": "${AI_GATEWAY_PROXY_LOCAL_KEY}",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "databricks-claude-opus-4-6",
            "name": "Claude Opus 4.6 (Databricks)"
          },
          {
            "id": "databricks-claude-opus-4-7",
            "name": "Claude Opus 4.7 (Databricks)"
          },
          {
            "id": "databricks-claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6 (Databricks)"
          },
          {
            "id": "databricks-claude-sonnet-4-5",
            "name": "Claude Sonnet 4.5 (Databricks)"
          }
        ]
      },
      "databricks-gemini": {
        "baseUrl": "http://127.0.0.1:${AI_GATEWAY_PROXY_PORT}/serving-endpoints/gemini",
        "apiKey": "${AI_GATEWAY_PROXY_LOCAL_KEY}",
        "api": "google-generative-ai",
        "models": [
          {
            "id": "databricks-gemini-3-1-pro",
            "name": "Gemini 3.1 Pro (Databricks)"
          },
          {
            "id": "databricks-gemini-3-1-flash-lite",
            "name": "Gemini 3.1 Flash Lite (Databricks)"
          },
          {
            "id": "databricks-gemini-3-pro",
            "name": "Gemini 3 Pro (Databricks)"
          },
          {
            "id": "databricks-gemini-3-flash",
            "name": "Gemini 3 Flash (Databricks)"
          },
          {
            "id": "databricks-gemini-2-5-pro",
            "name": "Gemini 2.5 Pro (Databricks)"
          },
          {
            "id": "databricks-gemini-2-5-flash",
            "name": "Gemini 2.5 Flash (Databricks)"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "databricks-openai/databricks-gpt-5-4"
      },
      "models": {
        "databricks-openai/databricks-gpt-5-4": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-anthropic/databricks-claude-opus-4-6": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-anthropic/databricks-claude-opus-4-7": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-anthropic/databricks-claude-sonnet-4-6": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-anthropic/databricks-claude-sonnet-4-5": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-gemini/databricks-gemini-3-1-pro": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-gemini/databricks-gemini-3-1-flash-lite": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-gemini/databricks-gemini-3-pro": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-gemini/databricks-gemini-3-flash": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-gemini/databricks-gemini-2-5-pro": {
          "params": {
            "transport": "sse"
          }
        },
        "databricks-gemini/databricks-gemini-2-5-flash": {
          "params": {
            "transport": "sse"
          }
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${TELEGRAM_ALLOWED_USER_ID}"],
      "groupPolicy": "open"
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "trustedProxies": ["0.0.0.0/0"],
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowInsecureAuth": true
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["${OPENCLAW_STATE_DIR}/workspace/skills"]
    },
    "entries": {
      "databricks-unity-catalog": { "enabled": true }
    }
  }
}